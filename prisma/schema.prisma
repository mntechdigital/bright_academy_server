generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RoleStatus {
  ACTIVE
  INACTIVE
}

model Role {
  id          String        @id @default(uuid())
  name        String        @unique
  status      RoleStatus    @default(ACTIVE)
  isDeleted   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  roleFeature RoleFeature[]
  adminUser   AdminUser[]
}

model RoleFeature {
  id     String @id @default(uuid())
  name   String
  index  Int
  path   String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
}

enum AdminUserStatus {
  ACTIVE
  INACTIVE
}

model AdminUser {
  id           String          @id @default(uuid())
  fullName     String
  email        String          @unique
  password     String
  profilePhoto String?         @db.LongText
  status       AdminUserStatus @default(ACTIVE)
  roleId       String
  role         Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

enum Status {
  ACTIVE
  INACTIVE
}

model Student {
  id                 String              @id @default(uuid())
  name               String
  stdRegNo           String?             
  classId            String
  stdClass           StdClass            @relation(fields: [classId], references: [id], onDelete: Cascade, map: "Student_stdClass_fkey")
  sectionId          String
  section            Section             @relation(fields: [sectionId], references: [id], onDelete: Cascade, map: "Student_section_fkey")
  parentPhone        String
  address            String
  gender             String
  weeklyMarksSheets  WeeklyMarksSheet[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  monthlyExamResults MonthlyExamResult[]
}

model StdClass {
  id                String             @id @default(uuid())
  className         String             @unique
  subjects          Subject[]
  sections          Section[]          @relation("ClassSections")
  students          Student[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  weeklyMarksSheets WeeklyMarksSheet[]
}

model Subject {
  id                 String              @id @default(uuid())
  subjectName        String
  classId            String
  stdClass           StdClass            @relation(fields: [classId], references: [id], onDelete: Cascade)
  weeklyMarksSheets  WeeklyMarksSheet[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  monthlyExamResults MonthlyExamResult[]

  @@unique([classId, subjectName])
}

model Section {
  id                String             @id @default(uuid())
  sectionName       String             @unique
  classes           StdClass[]         @relation("ClassSections")
  students          Student[]
  weeklyMarksSheets WeeklyMarksSheet[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Teacher {
  id        String   @id @default(uuid())
  name      String
  regNo     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeeklyMarksSheet {
  id            String   @id @default(uuid())
  month         String
  week          String
  publishedDate String
  year          String
  stdClass      StdClass @relation(fields: [stdClassId], references: [id])
  stdClassId    String
  section       Section  @relation(fields: [sectionId], references: [id])
  sectionId     String
  subject       Subject  @relation(fields: [subjectId], references: [id])
  subjectId     String
  student       Student? @relation(fields: [studentId], references: [id])
  studentId     String?
  totalMarks    Int
  obtainedMarks Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, subjectId, week, year])
}

model MonthlyExamResult {
  id String @id @default(uuid())

  student   Student @relation(fields: [studentId], references: [id])
  studentId String

  totalMarks Int
  gpa        Float
  grade      String
  position   String
  present    Int
  absent     Int

  month String?

  results SubjectResult[]

  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubjectResult {
  id          String @id @default(uuid())
  subjectName String
  marks       Int
  fullMarks   Int
  highestMark Int
  point       Float
  grade       String

  examResult   MonthlyExamResult @relation(fields: [examResultId], references: [id], onDelete: Cascade)
  examResultId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
